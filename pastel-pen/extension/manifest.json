{
  "manifest_version": 2,
  "name": "Pastel Pen",
  "version": "0.1.0",
  "description": "A local-only pastel highlighter for Firefox, with review pages saved in browser storage.",
  "permissions": ["<all_urls>", "activeTab", "menus", "storage", "tabs", "unlimitedStorage"],
  "browser_action": {
    "default_title": "Pastel Pen",
    "default_popup": "popup.html",
    "default_icon": "icons/pen.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "review.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/pen.svg",
    "96": "icons/pen.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "pastel-pen@aislop.local",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "142.0"
    }
  }
}
